{
  "name": "bimdown-cli",
  "version": "0.4.0",
  "description": "An open-source, AI-native building data format using CSV and SVG.",
  "author": "NovaShang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NovaShang/BimDown.git"
  },
  "homepage": "https://github.com/NovaShang/BimDown#readme",
  "bugs": {
    "url": "https://github.com/NovaShang/BimDown/issues"
  },
  "keywords": [
    "bim",
    "revit",
    "duckdb",
    "csv",
    "svg",
    "llm",
    "ai",
    "agent",
    "skill"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "type": "module",
  "bin": {
    "bimdown": "dist/cli.js"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.0-r.1",
    "commander": "^13.1.0",
    "fast-xml-parser": "^5.2.0",
    "fflate": "^0.8.2",
    "jsts": "^2.12.1",
    "sharp": "^0.34.5",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
